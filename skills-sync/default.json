{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Auto-sync @ozzylabs/gh-tasks skill bundle (ozzy-labs/gh-tasks) via Renovate customManagers + git-refs. Extend per-adapter sub-presets (skills-sync/<adapter-id>) to opt in to adapter outputs. See https://github.com/ozzy-labs/gh-tasks#skills-v010-target",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["**/.commons/sync.yaml"],
      "matchStrings": ["gh_tasks_commit:\\s*(?<currentDigest>[a-f0-9]{7,40})"],
      "currentValueTemplate": "main",
      "depNameTemplate": "ozzy-labs/gh-tasks",
      "packageNameTemplate": "https://github.com/ozzy-labs/gh-tasks",
      "datasourceTemplate": "git-refs"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["ozzy-labs/gh-tasks"],
      "matchDatasources": ["git-refs"],
      "commitMessageTopic": "gh-tasks skills",
      "commitMessageExtra": "to {{newDigestShort}}",
      "labels": ["chore", "gh-tasks-sync"],
      "semanticCommits": "enabled",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    }
  ]
}
