#!/usr/bin/env bash
# gh extension entry shim for `gh tasks`.
# Locates the precompiled binary for the current platform and execs it.
set -euo pipefail

EXTENSION_DIR="${BASH_SOURCE[0]%/*}"
case "$(uname -s)" in
  Darwin) os="darwin" ;;
  Linux) os="linux" ;;
  MINGW*|MSYS*|CYGWIN*) os="windows" ;;
  *) echo "Unsupported OS: $(uname -s)" >&2; exit 1 ;;
esac
case "$(uname -m)" in
  x86_64|amd64) arch="amd64" ;;
  arm64|aarch64) arch="arm64" ;;
  *) echo "Unsupported arch: $(uname -m)" >&2; exit 1 ;;
esac

binary="${EXTENSION_DIR}/packages/gh-tasks/bin/gh-tasks-${os}-${arch}"
[ "$os" = "windows" ] && binary="${binary}.exe"

if [ ! -x "$binary" ]; then
  echo "gh-tasks binary not found for ${os}-${arch}: ${binary}" >&2
  echo "Install via: gh extension install ozzy-labs/gh-tasks" >&2
  exit 1
fi

exec "$binary" "$@"
